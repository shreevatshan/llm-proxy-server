# LLM Proxy Server Environment Configuration

# Server Configuration
LLMPROXY_HOST=0.0.0.0
OPENAI_SERVER_PORT=11440
ANTHROPIC_SERVER_PORT=2027
MANAGEMENT_SERVER_PORT=8765

# Admin Configuration
LLMPROXY_ADMIN_ENABLED=true
LLMPROXY_ADMIN_USERNAME=admin
LLMPROXY_ADMIN_EMAIL=admin@localhost
LLMPROXY_ADMIN_PASSWORD=admin123

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./data/llm_proxy.db

# JWT Configuration (optional - defaults will be used if not set)
# SECRET_KEY=your-secret-key-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Development/Debug Settings (optional)
# DEBUG=false
# LOG_LEVEL=INFO

# OpenTelemetry Configuration (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=llm-proxy-server
#
# BatchSpanProcessor queue tuning. If logs show "Queue full, dropping Span"
# under load (the span export queue — owned by OpenLit's TracerProvider — is
# overflowing faster than the exporter drains it), raise the queue/batch sizes
# and/or shorten the schedule delay. The Bedrock provider itself creates no
# per-chunk spans, so this is the primary lever for that symptom.
# OTEL_BSP_MAX_QUEUE_SIZE=8192          # default 2048
# OTEL_BSP_MAX_EXPORT_BATCH_SIZE=1024   # default 512
# OTEL_BSP_SCHEDULE_DELAY=2000          # ms between exports, default 5000

# Bedrock concurrency bounds (optional; defaults shown). Govern how many
# concurrent Bedrock calls each path allows.
# BEDROCK_NATIVE_SEMAPHORE_LIMIT=15          # InvokeModel (non-stream Claude)
# BEDROCK_NATIVE_STREAM_SEMAPHORE_LIMIT=15   # InvokeModelWithResponseStream (Claude stream)
# BEDROCK_CONVERSE_SEMAPHORE_LIMIT=15        # Converse / converse_stream (OpenAI + non-Claude)
