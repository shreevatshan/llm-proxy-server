# ZOHO OAuth Configuration
# To enable ZOHO OAuth login, set the following environment variables:

# ZOHO OAuth Client ID (required)
# Get this from https://accounts.zoho.in/developerconsole
# ZOHO_CLIENT_ID=your_zoho_client_id_here

# ZOHO OAuth Client Secret (required)
# Get this from https://accounts.zoho.in/developerconsole
# ZOHO_CLIENT_SECRET=your_zoho_client_secret_here

# The redirect URI is automatically derived from LLMPROXY_DOMAIN and MANAGEMENT_SERVER_PORT
# (e.g. http://<LLMPROXY_DOMAIN>:<MANAGEMENT_SERVER_PORT>/auth/zoho/callback)
# Override ZOHO_REDIRECT_URI only if you need a custom value.

# Note: The base URL is automatically detected from https://accounts.zoho.in/oauth/serverinfo
# No need to manually configure the data center URL

# Example usage:
# export ZOHO_CLIENT_ID="your_client_id"
# export ZOHO_CLIENT_SECRET="your_client_secret"

# Notification Webhook Configuration
# Set this to receive notifications for various system events (user signups, etc.)
# NOTIFICATION_WEBHOOK_URL=https://your-webhook-endpoint.com/notifications

# Webhook Payload Format:
# All webhooks follow this structure:
# {
#   "event": "event_name",
#   "timestamp": "2024-01-01T12:00:00.000000",
#   "data": { ... event-specific data ... }
# }

# Example - User Signup Notification (text format for messaging platforms):
# {
#   "text": "🔔 New User Signup\n\n👤 **Username:** john_doe\n📧 **Email:** john@example.com\n🔐 **Signup Method:** Manual Signup\n📊 **Status:** ⏳ Pending Approval\n🆔 **User ID:** 123"
# }
#
# Other events may use the generic format:
# {
#   "event": "event_name",
#   "timestamp": "2024-01-01T12:00:00.000000",
#   "data": { ... }
# }
